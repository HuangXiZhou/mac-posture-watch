# Placement. `posture-watch adapt` updates this after camera-based placement detection.
PLACEMENT_PROFILE=default

# Camera
CAMERA_INDEX=0
FRAME_INTERVAL_SEC=2

# Baseline calibration
CALIBRATION_SEC=45
MIN_CALIBRATION_SAMPLES=12

# Local time-window scoring
LOCAL_WINDOW_SEC=90
LOCAL_SCORE_TRIGGER=70
LLM_VERIFY_SCORE=75
BAD_RATIO_REQUIRED=0.65
LOCAL_ONLY_NOTIFY_SCORE=82

# LLM verification. Disabled by default to keep image data local.
ENABLE_LLM_VERIFY=0
LLM_PROVIDER=openai_compatible
LLM_API_MODE=chat
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
OLLAMA_KEEP_ALIVE=30s
LLM_MIN_INTERVAL_SEC=600
MAX_LLM_CALLS_PER_HOUR=6
LLM_TIMEOUT_SEC=30
LLM_JSON_MODE=1
LLM_IMAGE_MAX_SIDE=512
LLM_JPEG_QUALITY=62
LLM_SEND_OVERLAY=1

# Notification
BARK_ENDPOINT=
MAC_NOTIFY=1
NOTIFY_COOLDOWN_SEC=900
RECOVERY_SEC=120

# Runtime paths. Empty means ~/Library/Application Support/posture-watch.
DATA_DIR=
BASELINE_PATH=

# Debug. Keep this disabled unless you explicitly want local debug images.
DEBUG_SAVE_FRAMES=0
